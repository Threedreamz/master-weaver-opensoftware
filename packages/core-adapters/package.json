{
  "name": "@opensoftware/core-adapters",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Adapter contracts every OpenSoftware module implements to expose its native records as canonical OpenSoftware types. Pairs with @opensoftware/core-types.",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint ok'"
  },
  "dependencies": {
    "@opensoftware/core-types": "workspace:*",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@opensoftware/tsconfig": "workspace:*",
    "typescript": "^5.9.3"
  }
}
