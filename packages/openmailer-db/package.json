{
  "name": "@opensoftware/openmailer-db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./dist/schema.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint ok'"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0",
    "pg": "^8.13.0",
    "@opensoftware/openmailer-core": "workspace:*"
  },
  "devDependencies": {
    "@opensoftware/tsconfig": "workspace:*",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.9.3"
  }
}
