{
  "name": "@opensoftware/openportal-realtime",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint ok'"
  },
  "dependencies": {
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.7.0",
    "@opensoftware/openportal-core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@opensoftware/tsconfig": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "typescript": "^5.9.3"
  }
}
