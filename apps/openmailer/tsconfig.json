{
  "extends": "@opensoftware/tsconfig/nextjs.json",
  "compilerOptions": {
    "noUncheckedIndexedAccess": false,
    "declaration": false,
    "declarationMap": false,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
